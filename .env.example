# =============================================================================
# RouteGen AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
# =============================================================================

# --- LLM API Keys (Free Tier Options) ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Ollama doesn't need an API key (local inference)

# --- Langfuse Observability ---
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_HOST=http://localhost:3001

# --- Database Connections (for local dev outside Docker) ---
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/routegen
MONGO_URI=mongodb://root:example@localhost:27017
REDIS_URL=redis://localhost:6379/0
CHROMA_URL=http://localhost:8001

# --- Budget Kill-Switch ---
BUDGET_CAP_USD=1.00

# --- Semantic Cache ---
CACHE_SIMILARITY_THRESHOLD=0.95

# --- App Settings ---
APP_ENV=development
LOG_LEVEL=INFO
